{
  "permissions": {
    "allow": [
      "Bash(./gradlew :buscourse:assembleDebug*)",
      "Bash(export JAVA_HOME=*)",
      "Bash(./gradlew :buscourse:dependencies*)",
      "Bash(git ls-tree *)",
      "Bash(javap*)",
      "Bash(git check-ignore*)",
      "Bash(adb -s * exec-out screencap*)",
      "Bash(adb -s * shell uiautomator dump*)",
      "Bash(export MSYS_NO_PATHCONV=1)",
      "Bash(adb -s * pull*)",
      "Bash(adb -s * logcat -d*)",
      "mcp__Claude_Preview__preview_console_logs",
      "mcp__Claude_Preview__preview_screenshot",
      "mcp__Claude_Preview__preview_snapshot",
      "mcp__Claude_Preview__preview_network",
      "mcp__claude-in-chrome__find",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__claude-in-chrome__read_page"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ ! -f \"$CLAUDE_PROJECT_DIR/.istech/CLAUDE.md\" ]; then echo 'WARNING: .istech サブモジュールが未初期化のため、istech 標準方針（CLAUDE.md）がロードされていません。CLAUDE.md の @.istech/... インポートはサイレントに失敗しています。可能なら git submodule update --init を実行してください。取得できない場合、リリース・配布・ネットワーク・署名に関わる作業を進めないでください。'; fi"
          }
        ]
      }
    ]
  }
}
